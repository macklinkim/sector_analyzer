{
  "mcpServers": {
    "fetch": {
      "command": "npx",
      "args": ["@anthropic-ai/fetch-mcp"]
    },
    "playwright": {
      "command": "npx",
      "args": ["@anthropic-ai/playwright-mcp"]
    },
    "newsapi": {
      "command": "python",
      "args": ["-m", "app.mcp.news_server"],
      "cwd": "./backend"
    }
  }
}
